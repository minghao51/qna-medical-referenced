
# =============================================================================
# Health Screening Interpreter Chatbot - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# See docs/configuration.md for detailed documentation
# =============================================================================

# -----------------------------------------------------------------------------
# Required Configuration
# -----------------------------------------------------------------------------

# Alibaba Dashscope API key for Qwen models
# Get your key at: https://dashscope-us.aliyuncs.com/
# Required for all LLM operations
DASHSCOPE_API_KEY=your-api-key-here

# -----------------------------------------------------------------------------
# LLM Configuration (Optional)
# -----------------------------------------------------------------------------

# LLM provider: "qwen" (direct Dashscope) or "litellm" (LiteLLM/OpenRouter)
# Default: qwen
# LLM_PROVIDER=qwen

# Qwen model to use for text generation (when LLM_PROVIDER=qwen)
# Options: qwen3.5-flash (fast, cost-effective), qwen3.5-plus, qwen-plus, qwen-max
# Default: qwen3.5-flash, qwen3-max-2026-01-23
MODEL_NAME=qwen3.5-27b

# -----------------------------------------------------------------------------
# LiteLLM / OpenRouter Configuration (Optional)
# -----------------------------------------------------------------------------

# OpenRouter API key (required when LLM_PROVIDER=litellm)
# Get your key at: https://openrouter.ai/settings/keys
# OPENROUTER_API_KEY=your-openrouter-key-here

# Default model for OpenRouter (when LLM_PROVIDER=litellm)
# See available models: https://openrouter.ai/models
# Default: google/gemma-4-31b-it
# OPENROUTER_MODEL=google/gemma-4-31b-it

# Generic LiteLLM model string (overrides OPENROUTER_MODEL if set)
# Format: "openrouter/google/gemma-4-31b-it", "openai/gpt-4o", etc.
# LITELLM_MODEL=

# Qwen embedding model for vector search
# Default: text-embedding-v4 (2048 dimensions)
# Note: Changing this requires re-indexing all documents
# EMBEDDING_MODEL=text-embedding-v4

# Qwen API base URL (OpenAI compatible)
# Default: US (Virginia) region
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# https://dashscope-us.aliyuncs.com/compatible-mode/v1

# -----------------------------------------------------------------------------
# Storage Configuration (Optional)
# -----------------------------------------------------------------------------

# Vector store collection name for vector storage
# Default: medical_docs
# Use different names for dev/prod/test isolation
# COLLECTION_NAME=medical_docs

# Directory for raw downloaded documents (HTML, PDF)
# Default: data/raw
# DATA_DIR=data/raw

# Directory for persistent vector index
# Default: data/vectors
# Important: Losing this directory requires re-indexing all documents
# VECTOR_DIR=data/vectors

# -----------------------------------------------------------------------------
# Chat Configuration (Optional)
# -----------------------------------------------------------------------------

# Maximum message length in characters
# Default: 2000 (roughly 500 tokens)
# Increase for complex queries, decrease for faster responses
# MAX_MESSAGE_LENGTH=2000

# -----------------------------------------------------------------------------
# API Configuration (Optional)
# -----------------------------------------------------------------------------

# Comma-separated list of valid API keys for authentication
# Default: (empty - authentication disabled)
# Format: key1,key2,key3
# Clients must include X-API-Key header matching one of these values
# Strongly recommended for production deployments
# API_KEYS=

# Maximum requests per minute per client IP
# Default: 60 (1 per second)
# Set to 0 to disable rate limiting (not recommended for production)
# RATE_LIMIT_PER_MINUTE=60

# -----------------------------------------------------------------------------
# Retry Configuration (Optional)
# -----------------------------------------------------------------------------

# Maximum retry attempts for failed LLM API calls
# Default: 3
# Uses exponential backoff strategy (1s, 2s, 4s delays)
# Set to 0 to disable retries
# MAX_RETRIES=3

# Initial retry delay in seconds
# Default: 1.0
# Actual delay = RETRY_DELAY * (2 ^ attempt_number)
# RETRY_DELAY=1.0

# -----------------------------------------------------------------------------
# Experiment Tracking Configuration (Optional)
# -----------------------------------------------------------------------------

# Weights & Biases API key for experiment tracking
# Default: (empty - wandb tracking disabled)
# Get your key at: https://wandb.ai/settings
# Required for logging runs and querying remote run history
WANDB_API_KEY=your-wandb-key-here

# Cache TTL for W&B history/run-detail cache (in seconds)
# Default: 60
# WANDB_CACHE_TTL_SECONDS=60
# -----------------------------------------------------------------------------
# Frontend Configuration (Optional)
# -----------------------------------------------------------------------------

# Backend API URL for frontend to connect to
# For local development: http://localhost:8000
# For Docker: http://localhost:8001
# VITE_API_URL=http://localhost:8000

# Test environment variables
GEMINI_API_KEY=your-gemini-key-here
# Gemini Models (externalized configuration)
GEMINI__MODEL=models/gemini-3-flash-preview

VITE_API_URL=http://localhost:8000
